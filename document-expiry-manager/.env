# Server Config
PORT=5000
MONGODB_URI=mongodb://localhost:27017/document_expiry
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRE=7d

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
